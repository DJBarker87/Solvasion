# Solana RPC
RPC_URL=https://api.devnet.solana.com
WS_URL=wss://api.devnet.solana.com

# Program
PROGRAM_ID=98VnxqEX7SBwLGJVAVeLSfQPEUDGwBEpQWwugvjPeAfM

# Crank keypair (JSON array of 64 bytes, or path to file)
CRANK_KEYPAIR_PATH=~/.config/solana/id.json

# Guardian service (optional — omit to disable)
GUARDIAN_KEYPAIR_PATH=~/.config/solana/guardian.json
GUARDIAN_MASTER_KEY=                  # 64-char hex string (32 bytes) for AES-256-GCM encryption

# Bot controller (optional — omit to disable)
BOT_SEED=                            # arbitrary string; bots derive keypairs via HMAC-SHA512

# Server
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Database (defaults to backend/db/solvasion.sqlite)
# DB_PATH=/custom/path/to/solvasion.sqlite
